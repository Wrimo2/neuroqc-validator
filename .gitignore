.gitignore
# Python bytecode
__pycache__/
*.pyc
*.py[cod]
*.so

# Virtual environments
.venv/
venv/
env/
ENV/
# Environment variables — CRITICAL
.env
.env.local
.env.production
*.env
!.env.example
# Flask uploaded files (user data, not code)
uploads/
instance/
# IDE / editor settings
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
# Logs and databases
*.log
*.sqlite
*.db
# Build artifacts
*.egg-info/
build/
dist/
# Jupyter
.ipynb_checkpoints/
# Compiled translations
*.mo
*.pot
